// Acorn & Ink — an enchanted library in the heart of the wood.
// Local dev uses SQLite (zero-setup). To deploy on Vercel, switch the
// datasource to Postgres (provider = "postgresql" + directUrl) — see DEPLOY.md.
// format/status are kept as validated strings (portable; no DB enums).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  image        String?
  bio          String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  books   Book[]
  notes   Note[]
  tasks   Task[]
  entries DiaryEntry[]
}

model Book {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  title         String
  author        String?
  format        String    @default("novel") // novel | manga | comic | other
  status        String    @default("want")  // want | reading | read | paused | dropped
  rating        Float? // 0.5 – 5 in half steps (rendered as mushrooms)
  review        String? // personal long-form review

  coverUrl      String?
  description   String?
  publisher     String?
  series        String?
  volume        Int?
  totalVolumes  Int?
  pageCount     Int?
  currentPage   Int?
  totalChapters Int? // for manga & comics: how many chapters in all
  currentChapter Int? // the chapter the reader is currently on
  isbn          String?
  olKey         String? // Open Library work/edition key
  publishedYear Int?

  startedAt     DateTime?
  finishedAt    DateTime?
  favorite      Boolean   @default(false)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  notes Note[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, format])
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookId    String?
  book      Book?    @relation(fields: [bookId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([bookId])
}

model Task {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  done      Boolean   @default(false)
  dueAt     DateTime?
  sort      Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
}

/// A diary written like an ancient spell-book: dated entries, many per day.
model DiaryEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  content   String
  mood      String? // a tiny glyph/word for the day's spirit
  entryDate DateTime @default(now()) // the day this entry belongs to
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, entryDate])
}
